<Window x:Class="PayrollSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PayrollSystem.Views"
        xmlns:vm="clr-namespace:PayrollSystem.ViewModels"
        Title="Payroll Management System"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Icon="/Logo/Payroll Icon.png">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeViewModel}">
            <views:EmployeeManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollViewModel}">
            <views:PayrollProcessingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayslipViewModel}">
            <views:PayslipView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BatchPrintViewModel}">
            <views:BatchPrintView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BiometricsViewModel}">
            <views:BiometricsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo / Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,18">
                    <Image Source="/Logo/Payroll Icon.png" Width="48" Height="48" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="PAYROLL" FontSize="16" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" FontFamily="{StaticResource HeadingFont}"/>
                    <TextBlock Text="Management System" FontSize="10" Foreground="#80CBC4"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <Border DockPanel.Dock="Top" Height="1" Background="#25BD6A" Margin="20,0"/>

                <!-- Bottom: User Info, Help & Logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,20">
                    <Border Height="1" Background="#2E7D32" Margin="0,0,0,16"/>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="White" FontSize="13"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentUserRole}" Foreground="#80CBC4" FontSize="11" Margin="0,2,0,8"/>
                    </StackPanel>
                    <Button Content="❔  Help Guide" Command="{Binding ToggleHelpCommand}" Style="{StaticResource NavButton}"
                            Foreground="#81D4FA" Margin="0,0,0,5"/>
                    <Button Content="🚪  Logout" Command="{Binding LogoutCommand}" Style="{StaticResource NavButton}"
                            Foreground="#EF9A9A"/>
                </StackPanel>

                <!-- Navigation (Middle - Fills Remaining Space) -->
                <StackPanel Margin="0,16,0,0">
                    <Button Content="📊  Dashboard" Command="{Binding NavigateDashboardCommand}" Style="{StaticResource NavButton}" x:Name="NavDashboard"/>
                    <Button Content="👥  Employees" Command="{Binding NavigateEmployeesCommand}" Style="{StaticResource NavButton}" x:Name="NavEmployees"/>
                    <Button Content="💵  Payroll" Command="{Binding NavigatePayrollCommand}" Style="{StaticResource NavButton}" x:Name="NavPayroll"/>
                    <Button Content="🧾  Payslip" Command="{Binding NavigatePayslipCommand}" Style="{StaticResource NavButton}" x:Name="NavPayslip"/>
                    <Button Content="📅  Biometrics" Command="{Binding NavigateBiometricsCommand}" Style="{StaticResource NavButton}" x:Name="NavBiometrics"/>
                    <Button Content="🖨️  Print Section" Command="{Binding NavigateBatchPrintCommand}" Style="{StaticResource NavButton}" x:Name="NavBatchPrint"/>
                    <Button Content="📋  Reports" Command="{Binding NavigateReportsCommand}" Style="{StaticResource NavButton}" x:Name="NavReports"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>
        </Border>

        <!-- ═══ GLOBAL HELP MODAL ═══ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsHelpModalVisible, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="12" Padding="40" Width="600" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="📖 How to Process Payroll" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Content="❌" Command="{Binding ToggleHelpCommand}" Background="Transparent" BorderThickness="0" Foreground="#757575" Cursor="Hand" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Close Help"/>
                    </Grid>

                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,20"/>

                    <!-- Steps -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Step 1: Import Biometrics (Once per period)" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Go to the 'Biometrics' tab on the left sidebar and click the Import button. Upload the Attendance Report (.xls) from your ZKTeco machine. The system will automatically detect the dates and attendance records." 
                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,15" LineHeight="20"/>

                        <TextBlock Text="Step 2: Generate Computations" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Proceed to the 'Payroll' tab. The system automatically reads your imported biometrics data. Simply search and select an employee from the dropdown. The system will auto-calculate their Basic Pay, Undertime, Late Deductions, and Net Pay based on their daily rate." 
                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,15" LineHeight="20"/>

                        <TextBlock Text="Step 3: Save the Record" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="In the 'Payroll' tab, review the deductions and add any Overtime, Bonuses, or Loans if applicable. Once finalized, click the green 'Process Payroll' button. This securely saves the record to the database." 
                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,15" LineHeight="20"/>

                        <TextBlock Text="Step 4: Print Payslips" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Go to the 'Print Section' tab. You will see a list of all processed payrolls. You can click 'Print All' to print everything at once, or select specific employees to print. You also have the option to Edit or Delete a record here before printing." 
                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,20" LineHeight="20"/>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Background="#F1F8E9" BorderBrush="#AED581" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Shortcut: You can skip Step 1 if you are only processing manual adjustments without an Excel file!" 
                                       FontSize="12" Foreground="#33691E" FontStyle="Italic" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Salamat Juswa!" Command="{Binding ToggleHelpCommand}" Style="{StaticResource PrimaryButton}"
                            Width="150" HorizontalAlignment="Center" Margin="0,25,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
