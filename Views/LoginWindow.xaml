<Window x:Class="PayrollSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login — Payroll Management System"
        Height="650" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="16" Background="White" BorderThickness="1" BorderBrush="#D0D0D0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="0,32,0,28" Background="#138A49">

                <StackPanel HorizontalAlignment="Center">
                    <!-- Logo -->
                    <Image Source="/Logo/Payroll Icon.png" Width="100" Height="100" 
                           HorizontalAlignment="Center" Margin="0,0,0,14"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="P A Y R O L L   S Y S T E M" FontSize="18" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" FontFamily="{StaticResource HeadingFont}"/>
                    <TextBlock Text="Enterprise Management Platform" FontSize="11" Foreground="#B2DFDB"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Close button (top-right) -->
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Close" Click="CloseButton_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>

            <!-- Close / Minimize buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Margin="0,10,10,0">
                <Button Content="─" Click="MinimizeButton_Click" Width="30" Height="30"
                        Background="Transparent" Foreground="#FFFFFF80" BorderThickness="0"
                        FontSize="12" Cursor="Hand" FontWeight="Bold"/>
                <Button Content="✕" Click="CloseButton_Click" Width="30" Height="30"
                        Background="Transparent" Foreground="#FFFFFF80" BorderThickness="0"
                        FontSize="13" Cursor="Hand"/>
            </StackPanel>

            <!-- ═══ FORM SECTION ═══ -->
            <StackPanel Grid.Row="1" Margin="36,24,36,24">

                <TextBlock Text="Welcome Back" FontSize="20" FontWeight="SemiBold"
                           Foreground="#212121" FontFamily="{StaticResource HeadingFont}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to your account to continue" FontSize="12"
                           Foreground="#9E9E9E" Margin="0,0,0,22"/>

                <!-- Error Message -->
                <Border x:Name="ErrorBorder" Visibility="Collapsed"
                        Background="#FFEBEE" CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Foreground="#C62828" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorText" Text="" Foreground="#C62828" FontSize="12"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Username -->
                <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}" Margin="2,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" x:Name="UsernameBorder">
                        <Grid>
                            <TextBlock Text="👤" FontSize="14" Margin="14,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="UsernameBox" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Padding="40,11,14,11" Foreground="#212121"
                                     FontFamily="{StaticResource PrimaryFont}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="UsernameBox_GotFocus" LostFocus="UsernameBox_LostFocus"
                                     TextChanged="UsernameBox_TextChanged"/>
                            <TextBlock x:Name="UsernamePlaceholder" Text="Enter your username"
                                       FontSize="13" Foreground="#BDBDBD" Padding="42,11,14,11"
                                       IsHitTestVisible="False" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Password -->
                <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}" Margin="2,0,0,6"/>
                <Grid Margin="0,0,0,10">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" x:Name="PasswordBorder">
                        <Grid>
                            <TextBlock Text="🔒" FontSize="14" Margin="14,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <!-- Password Box (visible by default) -->
                            <PasswordBox x:Name="PasswordBox" Background="Transparent" BorderThickness="0"
                                         FontSize="13" Padding="40,11,44,11" Foreground="#212121"
                                         FontFamily="{StaticResource PrimaryFont}"
                                         KeyDown="PasswordBox_KeyDown"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocusE"/>
                            <!-- Plain Text Box (hidden by default, for show password) -->
                            <TextBox x:Name="PasswordTextBox" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Padding="40,11,44,11" Foreground="#212121"
                                     FontFamily="{StaticResource PrimaryFont}" Visibility="Collapsed"
                                     TextChanged="PasswordTextBox_TextChanged"
                                     KeyDown="PasswordTextBox_KeyDown"/>
                            <!-- Placeholder -->
                            <TextBlock x:Name="PasswordPlaceholder" Text="Enter your password"
                                       FontSize="13" Foreground="#BDBDBD" Padding="42,11,14,11"
                                       IsHitTestVisible="False" VerticalAlignment="Center"/>
                            <!-- Eye Toggle Button -->
                            <Button x:Name="EyeToggle" Click="EyeToggle_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="36" Height="36" Margin="0,0,6,0" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                x:Name="eyeBg">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="eyeBg" Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="EyeIcon" Text="👁" FontSize="15" Foreground="#9E9E9E"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Remember Me -->
                <DockPanel Margin="0,0,0,20">
                    <CheckBox x:Name="RememberMeBox" DockPanel.Dock="Left" Content=" Remember me" FontSize="12"
                              Foreground="#757575" VerticalContentAlignment="Center"
                              IsChecked="{Binding RememberMe, Mode=TwoWay}"/>
                </DockPanel>

                <!-- Sign In Button -->
                <Button Click="LoginButton_Click" Height="46" IsDefault="True"
                        FontSize="14" FontWeight="Bold" Cursor="Hand" x:Name="SignInBtn">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" CornerRadius="8" Padding="0"
                                    Height="{TemplateBinding Height}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#25BD6A" Offset="0"/>
                                        <GradientStop Color="#42D480" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#138A49" Offset="0"/>
                                                <GradientStop Color="#25BD6A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#138A49"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="S I G N   I N" FontSize="14" FontWeight="Bold" Foreground="White"
                               FontFamily="{StaticResource HeadingFont}"/>
                </Button>

                <!-- Developer Credit -->
                <TextBlock Text="Developed by Lloyd Joshua De Lara" FontSize="12" Foreground="#757575" 
                           HorizontalAlignment="Center" Margin="0,24,0,0" FontWeight="Medium"
                           FontFamily="{StaticResource PrimaryFont}"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
