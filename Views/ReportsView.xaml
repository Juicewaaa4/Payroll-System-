<UserControl x:Class="PayrollSystem.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Reports &amp; Transaction History" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                    <TextBlock Text="View payroll records and employee deduction history" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                </StackPanel>
                
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand"
                        Command="{Binding DataContext.NavigateSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="settingsBtn" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Manage Users &amp; Roles" Foreground="#616161" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="settingsBtn" Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                       FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisConverter}}"/>

            <!-- Filter Bar -->
            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="FROM DATE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="150" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="TO DATE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="150" FontSize="13"/>
                    </StackPanel>

                    <!-- Export Button -->
                    <Button VerticalAlignment="Bottom" Cursor="Hand" Command="{Binding ExportExcelCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="exportBg" Background="{StaticResource PrimaryBrush}"
                                        CornerRadius="6" Padding="12,7">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Export Payroll" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="exportBg" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Payroll Records Table -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Payroll Records" Style="{StaticResource SectionTitle}" Margin="24,20,24,16"/>

                    <DataGrid ItemsSource="{Binding PayrollRecords}"
                              Style="{StaticResource ModernDataGrid}"
                              CellStyle="{StaticResource ModernDataGridCell}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              CanUserSortColumns="False"
                              AlternationCount="2"
                              AlternatingRowBackground="#F1F8E9"
                              MaxHeight="350">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                                <EventSetter Event="Click" Handler="DataGridColumnHeader_Click"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="EMP #" Binding="{Binding EmpNumber}" Width="85"/>
                            <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding PayrollDate}" Width="175"/>
                            <DataGridTextColumn Header="Gross" Binding="{Binding GrossSalary}" Width="95"/>
                            <DataGridTextColumn Header="SSS" Binding="{Binding Sss, StringFormat=₱{0:N2}}" Width="75"/>
                            <DataGridTextColumn Header="PAG-IBIG" Binding="{Binding Pagibig, StringFormat=₱{0:N2}}" Width="78"/>
                            <DataGridTextColumn Header="PhilHealth" Binding="{Binding Philhealth, StringFormat=₱{0:N2}}" Width="82"/>
                            <DataGridTextColumn Header="Loan" Binding="{Binding Loan, StringFormat=₱{0:N2}}" Width="65"/>
                            <DataGridTextColumn Header="Late" Binding="{Binding Late, StringFormat=₱{0:N2}}" Width="60"/>
                            <DataGridTextColumn Header="U.T." Binding="{Binding Undertime, StringFormat=₱{0:N2}}" Width="60"/>
                            <DataGridTextColumn Header="Others" Binding="{Binding Others, StringFormat=₱{0:N2}}" Width="65"/>
                            <DataGridTextColumn Header="Total Ded." Binding="{Binding Deductions}" Width="90"/>
                            <DataGridTextColumn Header="Net Pay" Binding="{Binding NetPay}" Width="95"/>
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                            <Setter Property="Foreground" Value="#25BD6A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination Controls -->
                    <Border Background="#FAFAFA" CornerRadius="0,0,8,8" Padding="16,10" Margin="0,0,0,16">
                        <DockPanel>
                            <!-- Footer count -->
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                <Run Text="Page "/>
                                <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="SemiBold" Foreground="#424242"/>
                                <Run Text=" of "/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="SemiBold" Foreground="#424242"/>
                            </TextBlock>
                            
                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button Content="&lt; Previous" Command="{Binding PreviousPageCommand}"
                                        Cursor="Hand" Padding="12,6" Margin="0,0,8,0" FontSize="12"
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Foreground="#424242"/>
                                
                                <Button Content="Next &gt;" Command="{Binding NextPageCommand}"
                                        Cursor="Hand" Padding="12,6" FontSize="12"
                                        Background="{StaticResource PrimaryBrush}" BorderThickness="0" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══ DEDUCTION HISTORY SECTION ═══ -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Background="{StaticResource SurfaceBrush}" Padding="24,16" CornerRadius="12,12,0,0">
                        <DockPanel>
                            <TextBlock Text="Employee Deduction History" Style="{StaticResource SectionTitle}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            
                            <!-- Export Button (Deductions) -->
                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                    Command="{Binding ExportDeductionsExcelCommand}"
                                    Visibility="{Binding HasDeductionRecords, Converter={StaticResource BoolToVisConverter}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="exportDedBg" Background="{StaticResource PrimaryBrush}"
                                                CornerRadius="6" Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Export Deduction History" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="exportDedBg" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- Search bar -->
                    <Border Padding="24,12,24,0">
                        <StackPanel>
                            <TextBlock Text="SEARCH EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"
                                     Text="{Binding DeductionSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox ItemsSource="{Binding FilteredDeductionEmployees}"
                                      SelectedItem="{Binding SelectedDeductionEmployee}"
                                      DisplayMemberPath="FullName"
                                      Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Border>

                    <!-- Selected Employee Deduction Summary -->
                    <Border Padding="24,0,24,20"
                            Visibility="{Binding SelectedDeductionEmployee, Converter={StaticResource NullToVisConverter}}">
                        <StackPanel>
                            <!-- Employee info header -->
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="16,10" Margin="0,0,0,12">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#138A49">
                                            <Run Text="{Binding SelectedDeductionEmployee.FullName}"/>
                                            <Run Text=" (" Foreground="#757575"/>
                                            <Run Text="{Binding SelectedDeductionEmployee.EmpNumber}" Foreground="#757575"/>
                                            <Run Text=")" Foreground="#757575"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,2,0,0">
                                            <Run Text="{Binding SelectedDeductionEmployee.Position}"/>
                                            <Run Text=" — Daily Rate: ₱"/>
                                            <Run Text="{Binding SelectedDeductionEmployee.DailyRate, StringFormat=N2}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontSize="12" Foreground="#757575">
                                        <Run Text="{Binding EmployeeDeductionRecords.Count, Mode=OneWay}"/>
                                        <Run Text=" payroll(s)"/>
                                    </TextBlock>
                                </DockPanel>
                            </Border>

                            <!-- Deduction records table -->
                            <DataGrid ItemsSource="{Binding EmployeeDeductionRecords}"
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                      CellStyle="{StaticResource ModernDataGridCell}"
                                      RowStyle="{StaticResource ModernDataGridRow}"
                                      AlternationCount="2"
                                      AlternatingRowBackground="#F1F8E9"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding PayrollDate}" Width="165"/>
                                    <DataGridTextColumn Header="Gross" Binding="{Binding GrossSalary}" Width="80"/>
                                    <DataGridTextColumn Header="SSS" Binding="{Binding Sss, StringFormat=₱{0:N2}}" Width="70"/>
                                    <DataGridTextColumn Header="PAG-IBIG" Binding="{Binding Pagibig, StringFormat=₱{0:N2}}" Width="70"/>
                                    <DataGridTextColumn Header="PhilHealth" Binding="{Binding Philhealth, StringFormat=₱{0:N2}}" Width="75"/>
                                    <DataGridTextColumn Header="Loan" Binding="{Binding Loan, StringFormat=₱{0:N2}}" Width="65"/>
                                    <DataGridTextColumn Header="Late" Binding="{Binding Late, StringFormat=₱{0:N2}}" Width="60"/>
                                    <DataGridTextColumn Header="Undertime" Binding="{Binding Undertime, StringFormat=₱{0:N2}}" Width="75"/>
                                    <DataGridTextColumn Header="Others" Binding="{Binding Others, StringFormat=₱{0:N2}}" Width="65"/>
                                    <DataGridTextColumn Header="Total Ded." Binding="{Binding Deductions}" Width="85"/>
                                    <DataGridTextColumn Header="Net Pay" Binding="{Binding NetPay}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Totals row -->
                            <Border Background="#FAFAFA" CornerRadius="0,0,8,8" Padding="16,10" Margin="0,4,0,0"
                                    Visibility="{Binding HasDeductionRecords, Converter={StaticResource BoolToVisConverter}}">
                                <Grid>
                                    <TextBlock Text="TOTALS:" FontSize="12" FontWeight="Bold" Foreground="#424242"/>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,10,0">
                                            <Run Text="SSS: ₱"/>
                                            <Run Text="{Binding TotalSss, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,10,0">
                                            <Run Text="PAGIBIG: ₱"/>
                                            <Run Text="{Binding TotalPagibig, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,10,0">
                                            <Run Text="Health: ₱"/>
                                            <Run Text="{Binding TotalPhilhealth, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,10,0">
                                            <Run Text="Loan: ₱"/>
                                            <Run Text="{Binding TotalLoan, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,10,0">
                                            <Run Text="Late/UT: ₱"/>
                                            <Run Text="{Binding TotalLate, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,15,0">
                                            <Run Text="Others: ₱"/>
                                            <Run Text="{Binding TotalOthers, StringFormat=N2}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="#E53935">
                                            <Run Text="Total Deductions: ₱"/>
                                            <Run Text="{Binding TotalAllDeductions, StringFormat=N2}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
