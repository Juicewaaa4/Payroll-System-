<UserControl x:Class="PayrollSystem.Views.PayslipView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Page Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Payslip Generator" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                    <TextBlock Text="Generate and print employee payslips" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                </StackPanel>
                
                <Button Grid.Column="1" Content="❓ Help" Command="{Binding ShowHelpCommand}" 
                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                        Foreground="#757575" Padding="12,6" Cursor="Hand" FontWeight="SemiBold" VerticalAlignment="Top"/>
            </Grid>

            <!-- ═══ CONTROLS ROW ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: Employee search + select + period -->
                    <WrapPanel Grid.Row="0">
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="SEARCH EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="200"
                                     Text="{Binding EmployeeSearch, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="SELECT EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding FilteredEmployees}" SelectedItem="{Binding SelectedEmployee}"
                                      DisplayMemberPath="FullName" Width="200" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="PERIOD START" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding PeriodStart}" Width="130" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="PERIOD END" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding PeriodEnd}" Width="130" FontSize="13"/>
                        </StackPanel>
                    </WrapPanel>

                    <!-- Row 2: Work params -->
                    <WrapPanel Grid.Row="2">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="DAYS" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="55" FontSize="13"
                                         Padding="6,8" Text="{Binding WorkDays, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="OT HRS" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="55" FontSize="13"
                                         Padding="6,8" Text="{Binding OvertimeHours, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="HOLIDAY" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="55" FontSize="13"
                                         Padding="6,8" Text="{Binding HolidayHours, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="ALLOW" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="65" FontSize="13"
                                         Padding="6,8" Text="{Binding AllowanceInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="BONUS" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="65" FontSize="13"
                                         Padding="6,8" Text="{Binding BonusInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="LOAN" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="65" FontSize="13"
                                         Padding="6,8" Text="{Binding LoanInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="LATE" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="65" FontSize="13"
                                         Padding="6,8" Text="{Binding LateInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="UNDERTIME" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="75" FontSize="13"
                                         Padding="6,8" Text="{Binding UndertimeInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="OTHERS" Style="{StaticResource FieldLabel}"/>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" MinWidth="65" FontSize="13"
                                         Padding="6,8" Text="{Binding OthersInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ═══ PAYSLIP DOCUMENT ═══ -->
            <Border Background="White" CornerRadius="4" BorderBrush="#B0B0B0" BorderThickness="1" Padding="40" Margin="0,20,0,0">
                <StackPanel>
                    <!-- Top Header -->
                    <Border Background="Black" Padding="15">
                        <TextBlock Text="{Binding CompanyName}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Address -->
                    <TextBlock Text="{Binding CompanyAddress}" Foreground="#333333" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                    <Border Height="1" Background="#E8E8E8" Margin="0,5,0,15"/>

                    <!-- Period -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="Payslip for the Period of " FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding PeriodText}" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>

                    <!-- Employee Info Table -->
                    <Border BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#1E7B44" Padding="10,6">
                                <TextBlock Text="Employee Information" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee Name:" FontWeight="SemiBold" Padding="10,4"/>
                                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#757575" BorderThickness="0,0,0,1" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding EmployeeName}" Padding="5,4"/>
                                </Border>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Employee ID:" FontWeight="SemiBold" Padding="10,4"/>
                                <Border Grid.Row="1" Grid.Column="1" BorderBrush="#757575" BorderThickness="0,0,0,1" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding EmpNumber}" Padding="5,4"/>
                                </Border>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Position:" FontWeight="SemiBold" Padding="10,4"/>
                                <Border Grid.Row="2" Grid.Column="1" BorderBrush="#757575" BorderThickness="0,0,0,1" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Position}" Padding="5,4"/>
                                </Border>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pay Period:" FontWeight="SemiBold" Padding="10,4"/>
                                <Border Grid.Row="3" Grid.Column="1" BorderBrush="#757575" BorderThickness="0,0,0,1" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding PeriodText}" Padding="5,4"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Main Grid Split -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="4.5*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Earnings Table -->
                        <Border Grid.Column="0" BorderBrush="DarkGray" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Background="#1E7B44" Padding="10,6" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Earnings" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                
                                <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Description" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        <TextBlock Grid.Column="1" Text="Rate Per Day" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        <TextBlock Grid.Column="2" Text="Days/Hrs" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        <TextBlock Grid.Column="3" Text="Amount" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="2">
                                    <StackPanel.Resources>
                                        <Style TargetType="Grid">
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="LightGray"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Data Rows -->
                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Basic Salary"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RatePerDay}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding WorkDays}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding BasicSalary, StringFormat=₱ {0}}" TextAlignment="Right"/>
                                    </Grid></Border>
                                    
                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Overtime Pay"/>
                                        <TextBlock Grid.Column="1" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding OvertimeHours}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding OtPay, StringFormat=₱ {0}}" TextAlignment="Right"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Holiday Pay"/>
                                        <TextBlock Grid.Column="1" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding HolidayHours}" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding HolidayPay, StringFormat=₱ {0}}" TextAlignment="Right"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Incentives / Bonus"/>
                                        <TextBlock Grid.Column="1" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding BonusAmount, StringFormat=₱ {0}}" TextAlignment="Right"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Allowance"/>
                                        <TextBlock Grid.Column="1" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="-" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding AllowanceTotal, StringFormat=₱ {0}}" TextAlignment="Right"/>
                                    </Grid></Border>
                                    
                                    <Border Background="#E8E8E8" BorderThickness="0" Margin="0,15,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Gross Earnings" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding GrossSalary, StringFormat=₱ {0}}" FontWeight="Bold" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Deductions Table -->
                        <Border Grid.Column="2" BorderBrush="DarkGray" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Background="#333333" Padding="10,6" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Deductions" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                
                                <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Description" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        <TextBlock Grid.Column="1" Text="Amount" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="2">
                                    <StackPanel.Resources>
                                        <Style TargetType="Grid">
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                        </Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="LightGray"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Editable bindings -->
                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="SSS Contribution"/>
                                        <TextBox Grid.Column="1" Text="{Binding Sss, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>
                                    
                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="PhilHealth"/>
                                        <TextBox Grid.Column="1" Text="{Binding Philhealth, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Pag-IBIG"/>
                                        <TextBox Grid.Column="1" Text="{Binding Pagibig, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Loan"/>
                                        <TextBox Grid.Column="1" Text="{Binding Loan, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Late"/>
                                        <TextBox Grid.Column="1" Text="{Binding Late, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Undertime"/>
                                        <TextBox Grid.Column="1" Text="{Binding Undertime, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Other Deductions"/>
                                        <TextBox Grid.Column="1" Text="{Binding Others, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid></Border>

                                    <!-- Padding equivalent row to match height -->
                                    <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text=" "/>
                                        <TextBlock Grid.Column="1" Text=" "/>
                                    </Grid></Border>
                                    
                                    <Border Background="#E8E8E8" BorderThickness="0" Margin="0,15,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Total Deductions" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalDeductions, StringFormat=₱ {0}}" FontWeight="Bold" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Summary Row -->
                    <Border Height="1" Background="DarkGray" Margin="0,20,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="Gross Earnings – Total Deductions = " FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="{Binding NetPay, StringFormat=₱ {0}}" FontWeight="Bold" FontSize="15" Foreground="#1E7B44"/>
                    </StackPanel>
                    <Border Height="1" Background="DarkGray" Margin="0,0,0,20"/>

                    <!-- Notes / Signatures -->
                    <Border BorderBrush="#E8E8E8" BorderThickness="1">
                        <StackPanel>
                            <Border Background="#1E7B44" Padding="10,6">
                                <TextBlock Text="Notes" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <Grid Margin="10,25,10,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Prepared by: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding PreparedBy, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Background="Transparent" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="5,2" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Approved by: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding ApprovedBy, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Background="Transparent" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="5,2" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <TextBlock VerticalAlignment="Center" Foreground="#757575" FontSize="12" FontStyle="Italic" Margin="0,0,15,0" Text="Click value numbers inside the table to override deductions 👆"/>
                        <Button Content="🖨  Print Section" Style="{StaticResource PrimaryButton}" Background="#333333" Command="{Binding DataContext.NavigateBatchPrintCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="20,10" Margin="0,0,10,0"/>
                        <Button Content="🖨  Print This Payslip" Style="{StaticResource PrimaryButton}" Command="{Binding PrintCommand}" Padding="20,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <!-- ═══ HELP MODAL ═══ -->
    <Border Background="#80000000" Visibility="{Binding IsHelpModalVisible, Converter={StaticResource BoolToVisConverter}}">
        <Border Background="White" CornerRadius="12" Padding="32" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="📖 How to Process Payroll" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="#1E7B44"/>
                
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="1. Select Employee" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Search and pick an employee from the dropdown menu to pull their basic salary configuration." TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="2. Set Period and Days" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Choose the Period Start and End dates for the payslip, and input the total worked days (e.g. 11 or 13 days)." TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>

                    <TextBlock Text="3. Input Additions and Deductions" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter override values for Overtime (OT HRS), Holiday Pay, Allowances, Bonuses, and any specific Deductions." TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>

                    <TextBlock Text="4. Generate &amp; Print" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Review the computed details in the preview below. Click 'Print This Payslip' to finish and automatically save the record." TextWrapping="Wrap" Foreground="#555"/>
                </StackPanel>

                <Button Content="Salamat Juswa!" Command="{Binding HideHelpCommand}" IsDefault="True"
                        Background="#1E7B44" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Border>
    </Grid>
</UserControl>
