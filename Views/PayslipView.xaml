<UserControl x:Class="PayrollSystem.Views.PayslipView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Page Header -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Payslip Generator" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="Generate and print employee payslips" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- ═══ CONTROLS ROW ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20">
                <WrapPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="SELECT EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                                  DisplayMemberPath="FullName" Width="220" Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="PERIOD START" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding PeriodStart}" Width="140" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="PERIOD END" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding PeriodEnd}" Width="140" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="DAYS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="60" Text="{Binding WorkDays, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="OT HRS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="60" Text="{Binding OvertimeHours, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="HOLIDAY" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="60" Text="{Binding HolidayHours, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="ALLOW" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="70" Text="{Binding AllowanceInput, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="BONUS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="70" Text="{Binding BonusInput, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="LOAN" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="70" Text="{Binding LoanInput, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="OTHERS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Width="70" Text="{Binding OthersInput, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- PAYSLIP DOCUMENT (Matching Reference Layout)       -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Background="White" CornerRadius="4" BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="0" x:Name="PayslipDocument">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Company Header -->
                        <RowDefinition Height="Auto"/> <!-- Employee Info -->
                        <RowDefinition Height="Auto"/> <!-- Salary Section -->
                        <RowDefinition Height="Auto"/> <!-- Basic + Gross -->
                        <RowDefinition Height="Auto"/> <!-- Deductions Header -->
                        <RowDefinition Height="Auto"/> <!-- Deductions Content -->
                        <RowDefinition Height="Auto"/> <!-- Net Pay -->
                        <RowDefinition Height="Auto"/> <!-- Signature -->
                    </Grid.RowDefinitions>

                    <!-- ─── ROW 0: Company Header ─── -->
                    <Grid Grid.Row="0" Margin="28,24,28,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding CompanyName}" FontSize="22" FontWeight="Bold"
                                       FontFamily="Segoe UI" Foreground="#1B5E20"/>
                            <TextBlock Text="{Binding CompanyAddress}" FontSize="12" FontStyle="Italic"
                                       Foreground="#757575" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding PeriodText}" FontSize="11" Foreground="#757575"
                                       HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <TextBlock Text="EMP #" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#424242" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border BorderBrush="#4CAF50" BorderThickness="1.5" CornerRadius="3" Padding="10,4">
                                    <TextBlock Text="{Binding EmpNumber}" FontSize="13" FontWeight="Bold"
                                               Foreground="#1B5E20"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- ─── ROW 1: Employee Info ─── -->
                    <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1"
                            Background="#FAFAFA" Padding="28,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="EMPLOYEE" FontSize="11" FontWeight="Bold" Foreground="#757575"/>
                                    <TextBlock Text="POSITION" FontSize="11" FontWeight="Bold" Foreground="#757575" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding EmployeeName}" FontSize="13" FontWeight="SemiBold" Foreground="#212121"/>
                                    <TextBlock Text="{Binding Position}" FontSize="13" Foreground="#424242" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,40,0">
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="RATE/DAY" FontSize="11" FontWeight="Bold" Foreground="#757575"/>
                                    <TextBlock Text="ALLOW/DAY" FontSize="11" FontWeight="Bold" Foreground="#757575" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding RatePerDay}" FontSize="13" Foreground="#212121"/>
                                    <TextBlock Text="{Binding AllowPerDay}" FontSize="13" Foreground="#212121" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ─── ROW 2: SALARY Header ─── -->
                    <Border Grid.Row="2" Background="#E8F5E9" Padding="28,8" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1">
                        <TextBlock Text="SALARY" FontSize="12" FontWeight="Bold" Foreground="#1B5E20"/>
                    </Border>

                    <!-- ─── ROW 3: Daily Salary Table + Earnings ─── -->
                    <Grid Grid.Row="3" Margin="28,0,28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="240"/>
                        </Grid.ColumnDefinitions>

                        <!-- Daily Salary Grid -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <!-- Day Headers -->
                            <UniformGrid Columns="7" Margin="0,8,0,0">
                                <TextBlock Text="MON" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="TUE" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="WED" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="THU" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="FRI" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="SAT" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                                <TextBlock Text="SUN" FontSize="10" FontWeight="Bold" Foreground="#757575" HorizontalAlignment="Center"/>
                            </UniformGrid>
                            <!-- Day Values -->
                            <UniformGrid Columns="7" Margin="0,4,0,12">
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1">
                                    <TextBlock Text="{Binding MonSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1">
                                    <TextBlock Text="{Binding TueSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1">
                                    <TextBlock Text="{Binding WedSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1">
                                    <TextBlock Text="{Binding ThuSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1">
                                    <TextBlock Text="{Binding FriSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1" Background="#FAFAFA">
                                    <TextBlock Text="{Binding SatSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#212121"/>
                                </Border>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="4,6" Margin="1" Background="#FAFAFA">
                                    <TextBlock Text="{Binding SunSalary}" FontSize="11" HorizontalAlignment="Center" Foreground="#757575"/>
                                </Border>
                            </UniformGrid>

                            <!-- Basic Salary -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="BASIC SALARY" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BasicSalary}" FontSize="13" FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Earnings Breakdown (right side) -->
                        <StackPanel Grid.Column="1" Margin="0,8,0,0">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="OT" FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="{Binding OtPay}" FontSize="12" HorizontalAlignment="Right" Foreground="#212121"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="ALLOW" FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="{Binding AllowanceTotal}" FontSize="12" HorizontalAlignment="Right" Foreground="#212121"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="HOLIDAY" FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="{Binding HolidayPay}" FontSize="12" HorizontalAlignment="Right" Foreground="#212121"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="BONUS" FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="{Binding BonusAmount}" FontSize="12" HorizontalAlignment="Right" Foreground="#212121"/>
                            </Grid>
                            <Border Height="1" Background="#E0E0E0" Margin="0,8,0,8"/>
                            <Grid>
                                <TextBlock Text="GROSS SALARY" FontSize="12" FontWeight="Bold" Foreground="#1B5E20"/>
                                <TextBlock Text="{Binding GrossSalary}" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="#1B5E20"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- ─── ROW 4: DEDUCTIONS Header ─── -->
                    <Border Grid.Row="4" Background="#F5F5F5" Padding="28,8" Margin="0,8,0,0"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,1">
                        <TextBlock Text="DEDUCTIONS" FontSize="12" FontWeight="Bold" Foreground="#424242"/>
                    </Border>

                    <!-- ─── ROW 5: Deductions Content ─── -->
                    <Grid Grid.Row="5" Margin="28,12,28,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Column 1: SSS, PAG-IBIG, PHILHEALTH -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="SSS" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding Sss}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="PAG-IBIG" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding Pagibig}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="PHILHEALTH" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding Philhealth}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Column 2: INCOME TAX, LOAN, OTHERS -->
                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="INCOME TAX" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding IncomeTax}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="LOAN" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding Loan}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="OTHERS" FontSize="11" Foreground="#424242"/>
                                <TextBlock Text="{Binding Others}" FontSize="12" HorizontalAlignment="Right" Foreground="#E53935" Margin="0,0,30,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Total Deductions -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,6">
                            <TextBlock Text="TOTAL DEDUCTIONS:" FontSize="11" FontWeight="Bold"
                                       Foreground="#424242" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding TotalDeductions}" FontSize="14" FontWeight="Bold"
                                       Foreground="#E53935" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ─── ROW 6: NET PAY ─── -->
                    <Border Grid.Row="6" Background="#2E7D32" Padding="28,14" Margin="0,0,0,0">
                        <Grid>
                            <TextBlock Text="NET PAY:" FontSize="16" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding NetPay}" FontSize="22" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ─── ROW 7: Signature & Actions ─── -->
                    <Grid Grid.Row="7" Margin="28,20,28,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PREPARED BY:" FontSize="11" FontWeight="Bold" Foreground="#757575"/>
                            <Border BorderBrush="#BDBDBD" BorderThickness="0,0,0,1" Width="180"
                                    HorizontalAlignment="Left" Margin="0,28,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="APPROVED BY:" FontSize="11" FontWeight="Bold" Foreground="#757575"/>
                            <Border BorderBrush="#BDBDBD" BorderThickness="0,0,0,1" Width="180"
                                    HorizontalAlignment="Left" Margin="0,28,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="🖨  Print" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding PrintCommand}" Margin="0,0,8,0"/>
                            <Button Content="📄  Export PDF" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding PrintCommand}"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
