<UserControl x:Class="PayrollSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">
                <!-- Header -->
                <DockPanel Margin="0,0,0,24">
                    <!-- Appearance Toggle (Right) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🌙 Dark Mode" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <ToggleButton IsChecked="{Binding IsDarkMode, Mode=TwoWay}" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bg" Width="40" Height="20" CornerRadius="10" Background="{DynamicResource BorderBrush}">
                                        <Ellipse x:Name="knob" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="2,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Title (Left) -->
                    <StackPanel>
                        <TextBlock Text="Settings &amp; Tools" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                        <TextBlock Text="Manage users, departments, backups, and generate annual reports" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    </StackPanel>
                </DockPanel>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,16"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisConverter}}"/>

                <!-- Tabs -->
                <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Tab Header -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12,12,0,0" Padding="20,0">
                            <StackPanel Orientation="Horizontal" Height="50">
                                <RadioButton Content="👥 Users" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,30,0" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=0}"/>
                                <RadioButton Content="🏢 Departments" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,30,0" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=1}"/>
                                <RadioButton Content="💾 Backup &amp; Restore" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,30,0" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=2}"/>
                                <RadioButton Content="🎄 13th-Month Pay" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=3}"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="{DynamicResource BorderBrush}"/>

                        <!-- Tab 0: USERS -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=0}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <TextBlock Text="Registered Accounts" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Command="{Binding AddUserCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="addBg" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,8">
                                                    <TextBlock Text="➕  Add User" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="addBg" Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>

                                <DataGrid ItemsSource="{Binding Users}"
                                          Style="{StaticResource ModernDataGrid}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                          CellStyle="{StaticResource ModernDataGridCell}"
                                          RowStyle="{StaticResource ModernDataGridRow}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                                        <DataGridTemplateColumn Header="Action" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Edit" Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#1976D2" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                                        <Button Content="🗑 Delete" Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="{DynamicResource ErrorBrush}" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>

                        <!-- Tab 1: DEPARTMENTS -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=1}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <TextBlock Text="Organization Departments" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Command="{Binding AddDeptCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="addBg2" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,8">
                                                    <TextBlock Text="➕  Add Department" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="addBg2" Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>

                                <DataGrid ItemsSource="{Binding Departments}"
                                          Style="{StaticResource ModernDataGrid}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                          CellStyle="{StaticResource ModernDataGridCell}"
                                          RowStyle="{StaticResource ModernDataGridRow}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Department Name" Binding="{Binding Name}" Width="200"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTemplateColumn Header="Action" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Edit" Command="{Binding DataContext.EditDeptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#1976D2" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                                        <Button Content="🗑 Delete" Command="{Binding DataContext.DeleteDeptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="{DynamicResource ErrorBrush}" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════════ -->
                        <!-- Tab 2: BACKUP & RESTORE                            -->
                        <!-- ═══════════════════════════════════════════════════ -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=2}">
                            <StackPanel>
                                <TextBlock Text="Database Backup &amp; Restore" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                <TextBlock Text="Create a full backup of your payroll data or restore from a previous backup file."
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,24" TextWrapping="Wrap"/>

                                <!-- Current Data Summary Card -->
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="📊 Current Data Summary" FontSize="14" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding DataStats}" FontSize="13" Foreground="#33691E" TextWrapping="Wrap" LineHeight="22"/>
                                    </StackPanel>
                                </Border>

                                <!-- Last Backup Info Card -->
                                <Border Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,0,24">
                                    <StackPanel>
                                        <TextBlock Text="🕐 Last Backup" FontSize="14" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding LastBackupInfo}" FontSize="13" Foreground="#1565C0" TextWrapping="Wrap" LineHeight="22"/>
                                    </StackPanel>
                                </Border>

                                <!-- Action Buttons -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Backup Button -->
                                    <Button Grid.Column="0" Command="{Binding BackupCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="backupBg" Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="24,20">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="💾" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Backup Now" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Save all data to a JSON file" FontSize="11" Foreground="#C8E6C9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="backupBg" Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Restore Button -->
                                    <Button Grid.Column="2" Command="{Binding RestoreCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="restoreBg" Background="#1565C0" CornerRadius="10" Padding="24,20">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="📂" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Restore from Backup" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Load data from a backup file" FontSize="11" Foreground="#BBDEFB" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="restoreBg" Property="Background" Value="#0D47A1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Backup Status Message -->
                                <Border Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,0"
                                        Visibility="{Binding BackupStatusMessage, Converter={StaticResource StringToVisConverter}}">
                                    <TextBlock Text="{Binding BackupStatusMessage}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" LineHeight="22"/>
                                </Border>

                                <!-- Safety Tips -->
                                <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                                    <StackPanel>
                                        <TextBlock Text="💡 Backup Tips" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• Create backups regularly, especially before making major changes" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Text="• Keep backup files in a safe location (USB drive, cloud storage)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Text="• Restoring a backup will REPLACE all current data" FontSize="12" Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBlock Text="• Default backup location: Documents / PayrollSystem Backups" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════════ -->
                        <!-- Tab 3: 13TH-MONTH PAY                              -->
                        <!-- ═══════════════════════════════════════════════════ -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=3}">
                            <StackPanel>
                                <TextBlock Text="13th-Month Pay Generator" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                <TextBlock Text="Compute the annual 13th-month pay for all employees based on Philippine labor law."
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <TextBlock Text="Formula:  13th-Month Pay  =  Total Basic Salary Earned During the Year  ÷  12"
                                           Foreground="#1565C0" FontSize="12" FontStyle="Italic" Margin="0,0,0,24"/>

                                <!-- Year Selection + Generate -->
                                <DockPanel Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <TextBlock Text="Year:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}"
                                                  Style="{StaticResource ModernComboBox}" Width="120" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <!-- Export Button -->
                                        <Button Command="{Binding Export13thMonthCommand}" Cursor="Hand" Margin="0,0,12,0"
                                                Visibility="{Binding HasThirteenthMonthData, Converter={StaticResource BoolToVisConverter}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="exportBg" Background="#1565C0" CornerRadius="6" Padding="16,8">
                                                        <TextBlock Text="📥 Export to Excel" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="exportBg" Property="Background" Value="#0D47A1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Generate Button -->
                                        <Button Command="{Binding Generate13thMonthCommand}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="genBg" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,8">
                                                        <TextBlock Text="🎄 Generate 13th-Month Pay" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="genBg" Property="Background" Value="#388E3C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Status Message -->
                                <TextBlock Text="{Binding ThirteenthMonthStatus}" Foreground="{StaticResource PrimaryBrush}"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,16" TextWrapping="Wrap"
                                           Visibility="{Binding ThirteenthMonthStatus, Converter={StaticResource StringToVisConverter}}"/>

                                <!-- Summary Cards (visible only when data exists) -->
                                <Grid Margin="0,0,0,20" Visibility="{Binding HasThirteenthMonthData, Converter={StaticResource BoolToVisConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Employees Card -->
                                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="👥" FontSize="22" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding TotalEmployeesComputed}" Style="{StaticResource StatValue}"/>
                                            <TextBlock Text="Employees" Style="{StaticResource StatLabel}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Total Basic Salary Card -->
                                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                        <StackPanel>
                                            <TextBlock Text="💵" FontSize="22" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding TotalBasicSalary}" Style="{StaticResource StatValue}" FontSize="22"/>
                                            <TextBlock Text="Total Basic Salary" Style="{StaticResource StatLabel}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 13th Month Total Card (highlighted) -->
                                    <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" CornerRadius="10" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="🎄" FontSize="22" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding TotalThirteenthMonthPay}" FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="22" FontWeight="Bold" Foreground="#2E7D32"/>
                                            <TextBlock Text="Total 13th-Month Pay" Style="{StaticResource StatLabel}" Foreground="#388E3C"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Results DataGrid -->
                                <DataGrid ItemsSource="{Binding ThirteenthMonthRecords}"
                                          Style="{StaticResource ModernDataGrid}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                          CellStyle="{StaticResource ModernDataGridCell}"
                                          RowStyle="{StaticResource ModernDataGridRow}"
                                          MaxHeight="400"
                                          Visibility="{Binding HasThirteenthMonthData, Converter={StaticResource BoolToVisConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="EMP #" Binding="{Binding EmpNumber}" Width="100"/>
                                        <DataGridTextColumn Header="Employee Name" Binding="{Binding EmployeeName}" Width="*"/>
                                        <DataGridTextColumn Header="Payroll Count" Binding="{Binding PayrollCount}" Width="120"/>
                                        <DataGridTextColumn Header="Total Basic Salary" Binding="{Binding TotalBasicSalaryFormatted}" Width="160"/>
                                        <DataGridTextColumn Header="13th-Month Pay" Binding="{Binding ThirteenthMonthPayFormatted}" Width="160">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state message when no data -->
                                <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="40" Margin="0,0,0,0"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasThirteenthMonthData, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🎄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Select a year and click Generate" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="The system will compute each employee's 13th-month pay from their payroll history."
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ USER MODAL ═══ -->
        <Border Background="{DynamicResource ModalOverlayBrush}" Visibility="{Binding IsUserFormVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{DynamicResource ModalBrush}" CornerRadius="12" Padding="32" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add User Account" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="ROLE" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Text="{Binding FormRole, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,24">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Staff"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelUserCommand}" IsCancel="True"
                                Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button Grid.Column="2" Content="💾 Save" Command="{Binding SaveUserCommand}" IsDefault="True"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ DEPARTMENT MODAL ═══ -->
        <Border Background="{DynamicResource ModalOverlayBrush}" Visibility="{Binding IsDeptFormVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{DynamicResource ModalBrush}" CornerRadius="12" Padding="32" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add Department" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="DEPARTMENT NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormDeptName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="DESCRIPTION (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormDeptDesc, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24" Height="60"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelDeptCommand}" IsCancel="True"
                                Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button Grid.Column="2" Content="💾 Save" Command="{Binding SaveDeptCommand}" IsDefault="True"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
