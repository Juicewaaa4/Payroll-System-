<UserControl x:Class="PayrollSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">
                <!-- Header -->
                <TextBlock Text="Manage Users &amp; Departments" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                <TextBlock Text="Manage registered user accounts and organization departments" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" Margin="0,0,0,24"/>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,16"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisConverter}}"/>

                <!-- Tabs -->
                <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Tab Header -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12,12,0,0" Padding="20,0">
                            <StackPanel Orientation="Horizontal" Height="50">
                                <RadioButton Content="👥 User Accounts" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,30,0" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=0}"/>
                                <RadioButton Content="🏢 Departments" GroupName="SettingsTabs" FontSize="14" FontWeight="SemiBold"
                                             Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=1}"/>
                            </StackPanel>
                        </Border>
                        <Border Height="1" Background="{StaticResource BorderBrush}"/>

                        <!-- Tab 0: USERS -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=0}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <TextBlock Text="Registered Accounts" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Command="{Binding AddUserCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="addBg" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,8">
                                                    <TextBlock Text="➕  Add User" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="addBg" Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>

                                <DataGrid ItemsSource="{Binding Users}"
                                          Style="{StaticResource ModernDataGrid}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                          CellStyle="{StaticResource ModernDataGridCell}"
                                          RowStyle="{StaticResource ModernDataGridRow}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                                        <DataGridTemplateColumn Header="Action" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Edit" Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#1976D2" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                                        <Button Content="🗑 Delete" Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#E53935" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>

                        <!-- Tab 1: DEPARTMENTS -->
                        <Grid Margin="24" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisConverter}, ConverterParameter=1}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <TextBlock Text="Organization Departments" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Command="{Binding AddDeptCommand}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="addBg2" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="16,8">
                                                    <TextBlock Text="➕  Add Department" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="addBg2" Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>

                                <DataGrid ItemsSource="{Binding Departments}"
                                          Style="{StaticResource ModernDataGrid}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                          CellStyle="{StaticResource ModernDataGridCell}"
                                          RowStyle="{StaticResource ModernDataGridRow}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Department Name" Binding="{Binding Name}" Width="200"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTemplateColumn Header="Action" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Edit" Command="{Binding DataContext.EditDeptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#1976D2" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                                        <Button Content="🗑 Delete" Command="{Binding DataContext.DeleteDeptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" Foreground="#E53935" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ USER MODAL ═══ -->
        <Border Background="#80000000" Visibility="{Binding IsUserFormVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="White" CornerRadius="12" Padding="32" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add User Account" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="ROLE" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Text="{Binding FormRole, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,24">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Staff"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelUserCommand}"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="#757575"/>
                        <Button Grid.Column="2" Content="💾 Save" Command="{Binding SaveUserCommand}"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ DEPARTMENT MODAL ═══ -->
        <Border Background="#80000000" Visibility="{Binding IsDeptFormVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="White" CornerRadius="12" Padding="32" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add Department" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="DEPARTMENT NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormDeptName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="DESCRIPTION (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormDeptDesc, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24" Height="60"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelDeptCommand}"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="#757575"/>
                        <Button Grid.Column="2" Content="💾 Save" Command="{Binding SaveDeptCommand}"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
