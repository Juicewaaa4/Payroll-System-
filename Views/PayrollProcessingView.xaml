<UserControl x:Class="PayrollSystem.Views.PayrollProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <TextBlock Text="Payroll Processing" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
            <TextBlock Text="Calculate and process employee payroll" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ LEFT: Input Panel ═══ -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                            <TextBlock Text="Payroll Details" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Searchable Employee Selection -->
                        <TextBlock Text="SEARCH &amp; SELECT EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"
                                 Text="{Binding EmployeeSearch, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox ItemsSource="{Binding FilteredEmployees}"
                                  SelectedItem="{Binding SelectedEmployee}"
                                  DisplayMemberPath="FullName"
                                  Style="{StaticResource ModernComboBox}" Margin="0,0,0,6"/>

                        <!-- Selected Employee Info -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,16" Visibility="{Binding SelectedEmployee, Converter={StaticResource NullToVisConverter}}">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding SelectedEmployee.FullName}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedEmployee.Position}"/>
                                    <Run Text=" — Daily Rate: ₱"/>
                                    <Run Text="{Binding SelectedEmployee.DailyRate, StringFormat=N2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Period -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PERIOD START" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding PeriodStart, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PERIOD END" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding PeriodEnd, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <!-- Work Days -->
                        <TextBlock Text="WORK DAYS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WorkDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <!-- OT and Holiday -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="OVERTIME HOURS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding OvertimeHours, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="HOLIDAY HOURS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding HolidayHours, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Allowance and Bonus -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ALLOWANCE" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Allowance, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BONUS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Bonus, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Process Button -->
                        <Button HorizontalAlignment="Right" Cursor="Hand"
                                Command="{Binding ProcessPayrollCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="procBg" Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="8" Padding="24,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💵" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Process Payroll" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource PrimaryFont}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="procBg" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="procBg" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource PrimaryGreenDark}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ═══ RIGHT: Computation Panel (Payslip Twin) ═══ -->
                <Border Grid.Column="2" Background="White" CornerRadius="4" BorderBrush="#B0B0B0" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Salary Computation" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>

                        <!-- Dual Tabular Grid to match Payslip -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- EARNINGS ROW -->
                            <Border Grid.Row="0" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Background="#1E7B44" Padding="10,6" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Earnings" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    
                                    <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Description" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                            <TextBlock Grid.Column="1" Text="Amount" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="2">
                                        <StackPanel.Resources>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0"/>
                                            </Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="5,6"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="LightGray"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Basic Salary"/>
                                            <TextBlock Grid.Column="1" Text="{Binding BasicSalary}" TextAlignment="Right"/>
                                        </Grid></Border>
                                        
                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Overtime Pay"/>
                                            <TextBlock Grid.Column="1" Text="{Binding OvertimePay}" TextAlignment="Right"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Holiday Pay"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HolidayPay}" TextAlignment="Right"/>
                                        </Grid></Border>
                                        
                                        <Border Background="#E8E8E8" BorderThickness="0" Margin="0,10,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Gross Earnings" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding GrossSalary}" FontWeight="Bold" TextAlignment="Right" Foreground="#1E7B44"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- DEDUCTIONS ROW -->
                            <Border Grid.Row="1" BorderBrush="DarkGray" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Background="#333333" Padding="10,6" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Deductions" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    
                                    <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Description (Editable 👇)" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                            <TextBlock Grid.Column="1" Text="Amount" FontWeight="SemiBold" TextAlignment="Center" Padding="5"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="2">
                                        <StackPanel.Resources>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0"/>
                                            </Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="5,6"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Padding" Value="5,6"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Background" Value="#FFF8E1"/> <!-- Light yellow to denote editable -->
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#D32F2F"/>
                                                <Setter Property="Margin" Value="2"/>
                                            </Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="LightGray"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="SSS Contribution"/>
                                            <TextBox Grid.Column="1" Text="{Binding SssDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>
                                        
                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PhilHealth"/>
                                            <TextBox Grid.Column="1" Text="{Binding PhilhealthDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Pag-IBIG"/>
                                            <TextBox Grid.Column="1" Text="{Binding PagibigDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Loan"/>
                                            <TextBox Grid.Column="1" Text="{Binding LoanDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Late"/>
                                            <TextBox Grid.Column="1" Text="{Binding LateDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Undertime"/>
                                            <TextBox Grid.Column="1" Text="{Binding UndertimeDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>

                                        <Border><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" IsEditable="True" ItemsSource="{Binding OtherDeductionTypes}" Text="{Binding OthersDeductionName, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Margin="2,0,5,0" Padding="3,6" VerticalAlignment="Center" Foreground="#333" TextSearch.TextPath=""/>
                                            <TextBox Grid.Column="1" Text="{Binding OthersDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid></Border>
                                        
                                        <Border Background="#E8E8E8" BorderThickness="0" Margin="0,10,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Total Deductions" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TotalDeductions}" FontWeight="Bold" TextAlignment="Right" Foreground="#D32F2F"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="DarkGray" Margin="0,20,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Net Pay (Gross – Deductions) = " FontWeight="Bold" FontSize="15"/>
                            <TextBlock Text="{Binding NetPay}" FontWeight="Bold" FontSize="15" Foreground="#1E7B44"/>
                        </StackPanel>
                        <Border Height="1" Background="DarkGray" Margin="0,0,0,0"/>

                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
