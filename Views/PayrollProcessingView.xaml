<UserControl x:Class="PayrollSystem.Views.PayrollProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <TextBlock Text="Payroll Processing" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
            <TextBlock Text="Calculate and process employee payroll" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ LEFT: Input Panel ═══ -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                            <TextBlock Text="Payroll Details" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Searchable Employee Selection -->
                        <TextBlock Text="SEARCH &amp; SELECT EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"
                                 Text="{Binding EmployeeSearch, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox ItemsSource="{Binding FilteredEmployees}"
                                  SelectedItem="{Binding SelectedEmployee}"
                                  DisplayMemberPath="FullName"
                                  Style="{StaticResource ModernComboBox}" Margin="0,0,0,6"/>

                        <!-- Selected Employee Info -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,16" Visibility="{Binding SelectedEmployee, Converter={StaticResource NullToVisConverter}}">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding SelectedEmployee.FullName}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedEmployee.Position}"/>
                                    <Run Text=" — Daily Rate: ₱"/>
                                    <Run Text="{Binding SelectedEmployee.DailyRate, StringFormat=N2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Period -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PERIOD START" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding PeriodStart, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PERIOD END" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding PeriodEnd, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <!-- Work Days -->
                        <TextBlock Text="WORK DAYS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding WorkDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <!-- OT and Holiday -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="OVERTIME HOURS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding OvertimeHours, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="HOLIDAY HOURS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding HolidayHours, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Allowance and Bonus -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ALLOWANCE" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Allowance, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BONUS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Bonus, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Process Button -->
                        <Button HorizontalAlignment="Right" Cursor="Hand"
                                Command="{Binding ProcessPayrollCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="procBg" Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="8" Padding="24,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💵" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Process Payroll" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource PrimaryFont}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="procBg" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="procBg" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource PrimaryGreenDark}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ═══ RIGHT: Computation Panel (Payslip Twin) ═══ -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Salary Computation" Style="{StaticResource SectionTitle}" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- EARNINGS ROW -->
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,12">
                                        <TextBlock Text="💵" Foreground="{DynamicResource PrimaryBrush}" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="EARNINGS" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="0" Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Bottom"/>
                                    
                                    <Grid Grid.Row="1" Margin="15,10,15,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Description" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="Amount" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" TextAlignment="Right"/>
                                    </Grid>

                                    <StackPanel Grid.Row="2" Margin="15,5,15,15">
                                        <StackPanel.Resources>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0,6"/>
                                            </Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Basic Salary"/>
                                            <TextBlock Grid.Column="1" Text="{Binding BasicSalary}" TextAlignment="Right" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Grid>
                                        
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Overtime Pay"/>
                                            <TextBlock Grid.Column="1" Text="{Binding OvertimePay}" TextAlignment="Right" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Holiday Pay"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HolidayPay}" TextAlignment="Right" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Padding="15,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GROSS EARNINGS" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding GrossSalary}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- DEDUCTIONS ROW -->
                            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,25">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,12">
                                        <TextBlock Text="🧾" Foreground="{DynamicResource ErrorBrush}" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="DEDUCTIONS" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="0" Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Bottom"/>
                                    
                                    <Grid Grid.Row="1" Margin="15,10,15,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Description (Editable 👇)" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="Amount" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" TextAlignment="Right"/>
                                    </Grid>

                                    <StackPanel Grid.Row="2" Margin="15,5,15,15">
                                        <StackPanel.Resources>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0,6"/>
                                            </Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="SSS Contribution"/>
                                            <TextBox Grid.Column="1" Text="{Binding SssDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>
                                        
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PhilHealth"/>
                                            <TextBox Grid.Column="1" Text="{Binding PhilhealthDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Pag-IBIG"/>
                                            <TextBox Grid.Column="1" Text="{Binding PagibigDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Loan"/>
                                            <TextBox Grid.Column="1" Text="{Binding LoanDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Late"/>
                                            <TextBox Grid.Column="1" Text="{Binding LateDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Undertime"/>
                                            <TextBox Grid.Column="1" Text="{Binding UndertimeDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Cash Advance"/>
                                            <TextBox Grid.Column="1" Text="{Binding CashAdvance, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>

                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding OthersDeductionName, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Left" Padding="0" Background="Transparent" BorderThickness="0"/>
                                            <TextBox Grid.Column="1" Text="{Binding OthersDeduction, UpdateSourceTrigger=PropertyChanged}" TextChanged="NumberTextBox_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Padding="15,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="TOTAL DEDUCTIONS" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalDeductions}" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Background="{DynamicResource NetPayBackgroundBrush}" CornerRadius="6" Padding="20,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NET PAY (Gross – Deductions)" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource NetPayTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding NetPay}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource NetPayTextBrush}" TextAlignment="Right"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
