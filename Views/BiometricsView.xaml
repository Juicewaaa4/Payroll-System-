<UserControl x:Class="PayrollSystem.Views.BiometricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">
                <!-- Header -->
                <TextBlock Text="Biometrics Import History" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                <TextBlock Text="Manage imported attendance Excel files from ZKTeco biometrics device" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" Margin="0,0,0,24"/>

                <!-- Controls Row -->
                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                    <DockPanel>
                        <!-- Left: Search -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="SEARCH IMPORTS" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Width="250"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right: Import Button -->
                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" FontSize="12"
                                       MaxWidth="350" TextTrimming="CharacterEllipsis"/>

                            <Button Command="{Binding ImportCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="importBtn" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="18,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📥" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Import Biometrics (Excel)" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="importBtn" Property="Background" Value="#1E7B44"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Data Table -->
                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <!-- Table -->
                        <DataGrid ItemsSource="{Binding FilteredRecords}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  MaxHeight="550" MinHeight="200">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Period Covered" Binding="{Binding PeriodRange}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Employees" Binding="{Binding EmployeeCount}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Imported On" Binding="{Binding ImportedAtFormatted}" Width="180"/>
                                <DataGridTemplateColumn Header="Action" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️ Delete" 
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" 
                                                    Foreground="{DynamicResource ErrorBrush}" Background="Transparent" BorderThickness="0" 
                                                    Cursor="Hand" FontSize="12" Padding="8,4" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Info Card -->
                <Border Style="{StaticResource Card}" Padding="18" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="ℹ️  How it works" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                            <Run FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">1.</Run>
                            <Run>Export an Attendance Report (.xls/.xlsx) from your ZKTeco/JKMall biometrics software.</Run>
                            <LineBreak/>
                            <Run FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">2.</Run>
                            <Run>Click "Import Biometrics (Excel)" above to upload it. The system will automatically detect employees, shifts, and attendance.</Run>
                            <LineBreak/>
                            <Run FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">3.</Run>
                            <Run>Go to the "Payroll" section → select an employee. The system will automatically read the latest imported biometrics and compute their attendance.</Run>
                            <LineBreak/>
                            <Run FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">4.</Run>
                            <Run>If you try to import the same Excel file twice, the system will block it to prevent duplicate data.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ DELETE CONFIRMATION MODAL ═══ -->
        <Border Background="{DynamicResource ModalOverlayBrush}" Visibility="{Binding IsDeleteModalVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{DynamicResource ModalBrush}" CornerRadius="12" Padding="32" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="⚠️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Delete Biometrics Record?" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DeleteTargetName}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" 
                               Margin="0,0,0,8" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="This will remove the import record permanently. You will be able to re-import the same file after deletion." 
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,24" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelDeleteCommand}" IsCancel="True"
                                Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button Grid.Column="2" Content="🗑️ Delete" Command="{Binding ConfirmDeleteCommand}" IsDefault="True"
                                Background="{DynamicResource DangerHoverBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold" BorderThickness="0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
        <!-- ═══ LOADING OVERLAY ═══ -->
        <Border Background="{DynamicResource ModalOverlayBrush}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}" Panel.ZIndex="100">
            <Border Background="{DynamicResource ModalBrush}" CornerRadius="12" Padding="40" Width="300" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <!-- Simple pure-XAML spinner -->
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Reading Excel File..." FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="This may take a few seconds depending on the file size." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
