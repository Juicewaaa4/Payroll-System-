<UserControl x:Class="PayrollSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,32">

                <!-- Page Header -->
                <TextBlock Text="{Binding Greeting}" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding CurrentDate}" Style="{StaticResource FieldLabel}" FontSize="13" Margin="0,0,0,28"/>

                <!-- ═══ NOTIFICATION / REMINDER BAR ═══ -->
                <Border Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisConverter}}"
                        CornerRadius="10" Padding="18,14" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#0D47A1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" VerticalAlignment="Center" Cursor="Hand"
                                Click="DismissNotification_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="closeBg" Background="#1E88E5" CornerRadius="4" Padding="10,4">
                                        <TextBlock Text="✕ Dismiss" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="closeBg" Property="Background" Value="#42A5F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontSize="13"
                                   FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,16,0"/>
                    </DockPanel>
                </Border>

                <!-- Stat Cards Row -->
                <UniformGrid Columns="4" Margin="0,0,0,28">
                    <!-- Total Employees -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalEmployees}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="Total Employees" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </Border>

                    <!-- Active Departments -->
                    <Border Style="{StaticResource StatCard}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="🏢" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ActiveDepartments}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="Departments" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Payroll -->
                    <Border Style="{StaticResource StatCard}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="💰" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalPayroll}" Style="{StaticResource StatValue}" FontSize="22"/>
                            <TextBlock Text="Payroll This Month" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pending -->
                    <Border Style="{StaticResource StatCard}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="📝" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding PendingPayroll}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="Pending Payroll" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ═══ PAYROLL EXPENSE TREND (BAR CHART) ═══ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,28">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="📊 Payroll Expense Trend" Style="{StaticResource SectionTitle}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <TextBlock Text="Last 6 Months" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>

                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20,16">
                            <ItemsControl ItemsSource="{Binding MonthlyExpenses}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" Margin="4,0">
                                            <!-- Amount label above bar -->
                                            <TextBlock Text="{Binding TotalFormatted}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                                            <!-- The bar itself -->
                                            <Border Width="40" Height="{Binding BarHeight}" CornerRadius="4,4,0,0"
                                                    VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#43A047" Offset="0"/>
                                                        <GradientStop Color="#1B5E20" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Month label -->
                                            <TextBlock Text="{Binding MonthLabel}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding YearLabel}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Recent Activity -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Recent Activity" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>

                        <DataGrid ItemsSource="{Binding RecentActivities}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="160"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
