<UserControl x:Class="PayrollSystem.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">

                <!-- Header Row -->
                <DockPanel Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Employee Management" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Manage your team members" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Compact Add Button -->
                    <Button DockPanel.Dock="Right" VerticalAlignment="Center"
                            Command="{Binding AddEmployeeCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="addBtnBorder" Background="{StaticResource PrimaryBrush}"
                                        CornerRadius="8" Padding="16,9">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add Employee" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource PrimaryFont}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="addBtnBorder" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="addBtnBorder" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{StaticResource PrimaryGreenDark}"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <!-- Search Bar -->
                <Border Style="{StaticResource Card}" Padding="4,4" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="🔍" FontSize="14" Margin="14,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBox Background="Transparent" BorderThickness="0"
                                 FontSize="13" Padding="38,10,14,10" Foreground="#212121"
                                 FontFamily="{StaticResource PrimaryFont}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SearchBox"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search by name, position, EMP #, or department..."
                                   FontSize="13" Foreground="#BDBDBD" Padding="40,10,14,10"
                                   IsHitTestVisible="False" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Employee Table -->
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding FilteredEmployees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              CellStyle="{StaticResource ModernDataGridCell}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              MinHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="EMP #" Binding="{Binding EmpNumber}" Width="85"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="150"/>
                            <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="120"/>
                            <DataGridTextColumn Header="Daily Rate" Binding="{Binding DailyRateFormatted}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                            <DataGridTemplateColumn Header="" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <!-- Edit icon button -->
                                            <Button Cursor="Hand" ToolTip="Edit"
                                                    Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="editBg" Background="Transparent"
                                                                CornerRadius="4" Padding="6,4" Margin="0,0,4,0">
                                                            <TextBlock Text="✏️" FontSize="13"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="editBg" Property="Background" Value="#E8F5E9"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- Delete icon button -->
                                            <Button Cursor="Hand" ToolTip="Delete"
                                                    Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="delBg" Background="Transparent"
                                                                CornerRadius="4" Padding="6,4">
                                                            <TextBlock Text="🗑️" FontSize="13"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="delBg" Property="Background" Value="#FFEBEE"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Footer count -->
                <TextBlock Margin="4,10,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Showing "/>
                    <Run Text="{Binding FilteredEmployees.Count, Mode=OneWay}"/>
                    <Run Text=" employee(s)"/>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ ADD/EDIT FORM OVERLAY ═══ -->
        <Border Background="#80000000" Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisConverter}}"
                x:Name="FormOverlay">
                <Border Background="White" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                    CornerRadius="12" Padding="0" BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <!-- Modal Header -->
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12,12,0,0" Padding="24,18">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource HeadingFont}"
                                       Text="Add New Employee"/>
                            <Button DockPanel.Dock="Right" Content="✕" HorizontalAlignment="Right"
                                    Command="{Binding CancelFormCommand}" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0" FontSize="16"
                                    Foreground="#9E9E9E" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Form body -->
                    <StackPanel Margin="24,20,24,24">
                        <!-- Error -->
                        <Border Visibility="{Binding FormError, Converter={StaticResource StringToVisConverter}}"
                                Background="#FFEBEE" CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
                            <TextBlock Text="{Binding FormError}" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Name row -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FIRST NAME" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FormFirstName}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FormLastName}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="POSITION" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FormPosition}" Margin="0,0,0,14"/>

                        <!-- Rate + Department row -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DAILY RATE (₱)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FormDailyRate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DEPARTMENT" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Departments}"
                                          Text="{Binding FormDepartment, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="HIRE DATE" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FormHireDate}" Margin="0,0,0,20"/>

                        <!-- Action buttons -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cancel Button -->
                            <Button Grid.Column="0" Command="{Binding CancelFormCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBg" Background="White" CornerRadius="8"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0,11">
                                            <TextBlock Text="Cancel" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#757575" HorizontalAlignment="Center"
                                                       FontFamily="{StaticResource PrimaryFont}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBg" Property="Background" Value="#F5F5F5"/>
                                                <Setter TargetName="cancelBg" Property="BorderBrush" Value="#BDBDBD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Save Button -->
                            <Button Grid.Column="2" Command="{Binding SaveEmployeeCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="saveBg" Background="{StaticResource PrimaryBrush}"
                                                CornerRadius="8" Padding="0,11">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="💾" FontSize="12" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Save Employee" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="White" VerticalAlignment="Center"
                                                           FontFamily="{StaticResource PrimaryFont}"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="saveBg" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource HoverGreen}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="saveBg" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource PrimaryGreenDark}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
