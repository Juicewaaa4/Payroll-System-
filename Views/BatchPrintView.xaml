<UserControl x:Class="PayrollSystem.Views.BatchPrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">
                <!-- Header -->
                <TextBlock Text="Payslip Print Section" Style="{StaticResource PageTitle}" Margin="0,0,0,4"/>
                <TextBlock Text="Print multiple processed payslips compactly on long bond paper" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" Margin="0,0,0,24"/>

                <!-- Filters & Controls -->
                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                    <DockPanel>
                        <!-- Top left: Date range filters -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="START DATE" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding StartDate}" Width="140" Padding="5" BorderBrush="{StaticResource BorderBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="END DATE" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding EndDate}" Width="140" Padding="5" BorderBrush="{StaticResource BorderBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Top right: Print action -->
                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold"/>
                                       
                            <!-- Print Selected Button -->
                            <Button Command="{Binding PrintSelectedCommand}" Cursor="Hand" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="printBtn" Background="#1565C0" CornerRadius="6" Padding="15,10">
                                            <TextBlock Text="🖨️ Print Selected" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="printBtn" Property="Background" Value="#0D47A1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Print All Button -->
                            <Button Command="{Binding PrintAllCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="printAllBtn" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="15,10">
                                            <TextBlock Text="📑 Print All (Batch)" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="printAllBtn" Property="Background" Value="#1E7B44"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Data Table -->
                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <!-- Table -->
                        <DataGrid ItemsSource="{Binding PayrollRecords}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  MaxHeight="500">
                            
                            <DataGrid.Columns>
                                <!-- Checkbox Column -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding DataContext.SelectAll, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="EMP. #" Binding="{Binding Record.EmpNumber}" Width="100"/>
                                <DataGridTextColumn Header="Employee Name" Binding="{Binding Record.EmployeeName}" Width="*"/>
                                <DataGridTextColumn Header="Payroll Date" Binding="{Binding Record.PayrollDateFormatted}" Width="145"/>
                                <DataGridTextColumn Header="Gross Pay" Binding="{Binding Record.GrossSalary}" Width="110"/>
                                <DataGridTextColumn Header="Net Pay" Binding="{Binding Record.NetPay}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Record.Status}" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Record.Status}" Value="Pending">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Record.Status}" Value="Paid">
                                                                <Setter Property="Foreground" Value="#25BD6A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Action" Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="✏️ Edit" Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Foreground="#1976D2" Background="Transparent" BorderThickness="0" 
                                                        Cursor="Hand" FontSize="12" Padding="6,3"/>
                                                
                                                <Button Content="❌ Delete" Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Foreground="#D32F2F" Background="Transparent" BorderThickness="0" 
                                                        Cursor="Hand" FontSize="12" Padding="6,3" Margin="2,0,0,0"/>
                                                
                                                <Button Command="{Binding DataContext.ApproveRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" Margin="4,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                            <Setter Property="Foreground" Value="#25BD6A"/>
                                                            <Setter Property="BorderBrush" Value="#81C784"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Padding" Value="8,3"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Content" Value="✅ Approve"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Record.Status}" Value="Pending">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ EDIT RECORD MODAL ═══ -->
        <Border Background="#80000000" Visibility="{Binding IsEditModalVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="White" CornerRadius="12" Padding="32" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Edit Payroll Record" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding EditTargetName}" FontSize="13" Foreground="#757575" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="GROSS SALARY (RAW)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditGross, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SSS" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditSss, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="PhilHealth" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditPhilhealth, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Late" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditLate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Others" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditOthers, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PAG-IBIG" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditPagibig, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Loan" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditLoan, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Undertime" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditUndertime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL DEDUCTIONS" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditDeductions, Mode=OneWay}" IsReadOnly="True" Background="#F0F0F0" Style="{StaticResource ModernTextBox}" Margin="0,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NET PAY" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding EditNetPay, Mode=OneWay}" IsReadOnly="True" Background="#F0F0F0" Style="{StaticResource ModernTextBox}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelEditCommand}" IsCancel="True"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="#757575"/>
                        <Button Grid.Column="2" Content="💾 Save" Command="{Binding SaveEditCommand}" IsDefault="True"
                                Background="{StaticResource PrimaryBrush}" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ DELETE CONFIRMATION MODAL ═══ -->
        <Border Background="#80000000" Visibility="{Binding IsDeleteModalVisible, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="White" CornerRadius="12" Padding="32" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="⚠️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Delete Payroll Record?" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DeleteTargetName}" FontSize="13" Foreground="#757575" HorizontalAlignment="Center" 
                               Margin="0,0,0,8" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="This will permanently remove this payslip record from the system. This action cannot be undone." 
                               FontSize="12" Foreground="#9E9E9E" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,24" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelDeleteCommand}" IsCancel="True"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand" Padding="0,11" Foreground="#757575"/>
                        <Button Grid.Column="2" Content="🗑️ Delete" Command="{Binding ConfirmDeleteCommand}" IsDefault="True"
                                Background="#D32F2F" Foreground="White" Cursor="Hand" Padding="0,11" FontWeight="SemiBold" BorderThickness="0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
